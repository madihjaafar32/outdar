# ============================================
# OUTDAR Backend — Environment Variables
# ============================================
# Copy this file to .env and fill in the values
# NEVER commit .env to git (it's in .gitignore)

# ============================================
# Server
# ============================================
NODE_ENV=development
PORT=5000

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# ============================================
# Database — MongoDB Atlas
# ============================================
# Get this from: cloud.mongodb.com → Connect → Drivers
# Format: mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/DATABASE_NAME
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/outdar?retryWrites=true&w=majority

# ============================================
# Authentication — JWT
# ============================================
# Generate a strong secret: run `openssl rand -base64 32` in terminal
# Or use any random 32+ character string
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars
JWT_EXPIRES_IN=7d

# ============================================
# Cloudinary (image hosting)
# ============================================
# Sign up free at: cloudinary.com
# Get credentials from: Dashboard → Account Details
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ============================================
# Anthropic Claude API (AI Assistant)
# ============================================
# Get a key from: console.anthropic.com
# $5 free credits available — no card required
ANTHROPIC_API_KEY=your_anthropic_api_key

# ============================================
# Email (optional, for later)
# ============================================
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your_email@gmail.com
# EMAIL_PASS=your_app_password
